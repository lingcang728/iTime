{
  "name": "itime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/visual-test.ps1",
    "visual:compare": "node scripts/compare-visual.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "verify": "npm run test && npm run build && cargo test --manifest-path src-tauri/Cargo.toml",
    "verify:full": "npm run verify && npm run test:visual"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "ssim.js": "^3.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
