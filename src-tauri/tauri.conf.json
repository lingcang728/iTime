{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iTime",
  "version": "0.1.0",
  "identifier": "com.itime.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "iTime",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "记录你的屏幕时间，也记录 AI 替你工作的时间。",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
