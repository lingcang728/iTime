{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iTime",
  "version": "0.1.0",
  "identifier": "com.itime.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "iTime",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/iTime/Cache/Icons/**/*"]
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "本机记录屏幕时间，并区分 AI 工具前台活动。",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
